# ─── Public site URLs ──────────────────────────────────────────────────
# Used to detect apex vs subdomain in proxy.ts.
NEXT_PUBLIC_ROOT_DOMAIN=qdx.one

# Used for invitation links and as the default base when generating URLs.
# In dev: http://localhost:3000  (use http://<slug>.localhost:3000 for tenants)
# In prod: https://qdx.one
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (required) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe (required for paid plans; optional during trials) ──────────
# Secret key. Use a test key in dev.
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (from `stripe listen` or your dashboard).
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs created in your Stripe dashboard. Per plan: flat monthly + annual
# base prices, plus a metered overage price ($3/Starter, $2/Growth per completed
# assessment past quota) in BOTH intervals — Stripe requires all recurring
# prices on a subscription to share one interval, so overage matches the base
# cycle. The overage prices aggregate a Billing Meter with event_name
# "assessment_completed" (default payload keys: stripe_customer_id + value).
# Full walkthrough: docs/stripe-setup.md.
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_STARTER_OVERAGE_MONTHLY=price_...
STRIPE_PRICE_STARTER_OVERAGE_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_GROWTH_OVERAGE_MONTHLY=price_...
STRIPE_PRICE_GROWTH_OVERAGE_ANNUAL=price_...

# ─── Resend (optional) ─────────────────────────────────────────────────
# If unset, the app still works — admins copy invitation links manually.
RESEND_API_KEY=
RESEND_FROM="qdx <careers@qdx.one>"

# ─── Operator (super-admin) access ─────────────────────────────────────
# Comma-separated list of emails allowed to access /super on the apex.
PLATFORM_OWNER_EMAILS=you@example.com

# ─── AI (job descriptions via Vercel AI Gateway; optional) ─────────────
AI_GATEWAY_API_KEY=
# Optional model override (default: anthropic/claude-haiku-4.5)
AI_MODEL=

# ─── Twilio SMS (optional; needs A2P 10DLC registration in the US) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
